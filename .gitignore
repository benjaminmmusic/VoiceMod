# Claude Code: track shared settings, ignore everything else
# (personal overrides go in .claude/settings.local.json; subagent workspaces etc. also ignored)
.claude/*
!.claude/settings.json

# Log files
*.log

# Build output
bin/
obj/
out/

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.user
*.suo

# Test results / coverage
[Tt]est[Rr]esult*/
coverage/
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
packages/
**/packages/*
!**/packages/build/

# Misc OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
