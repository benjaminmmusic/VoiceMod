<Window x:Class="VoiceMod.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceMod" Height="380" Width="540"
        ResizeMode="CanMinimize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Input:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="InputDeviceCombo" Margin="8,0,0,8"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Output:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="OutputDeviceCombo" Margin="8,0,0,16"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Effect:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="EffectCombo" Margin="8,0,0,16" SelectionChanged="EffectCombo_SelectionChanged">
            <ComboBoxItem Content="Pitch"/>
            <ComboBoxItem Content="Robot"/>
            <ComboBoxItem Content="Echo"/>
        </ComboBox>

        <Label x:Name="PitchLabelLeft" Grid.Row="3" Grid.Column="0" Content="Pitch:" VerticalAlignment="Center"/>
        <DockPanel x:Name="PitchRow" Grid.Row="3" Grid.Column="1" Margin="8,0,0,0">
            <TextBlock x:Name="PitchLabel" Text="+0 semitones" Width="110" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Slider x:Name="PitchSlider" Minimum="-12" Maximum="12" Value="0" TickFrequency="1" IsMoveToPointEnabled="True" IsSnapToTickEnabled="True" TickPlacement="BottomRight" ValueChanged="PitchSlider_ValueChanged"/>
        </DockPanel>

        <Label x:Name="RingModLabelLeft" Grid.Row="4" Grid.Column="0" Content="Robot:" VerticalAlignment="Center"/>
        <DockPanel x:Name="RingModRow" Grid.Row="4" Grid.Column="1" Margin="8,0,0,0">
            <TextBlock x:Name="RingModLabel" Text="+0 hz" Width="110" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Slider x:Name="RingModSlider" Minimum="0" Maximum="2000" Value="0" TickFrequency="100" IsMoveToPointEnabled="True" IsSnapToTickEnabled="True" TickPlacement="BottomRight" ValueChanged="RingModSlider_ValueChanged"/>
        </DockPanel>

        <Label x:Name="RampLabelLeft" Grid.Row="5" Grid.Column="0" Content="Ramp:" VerticalAlignment="Center"/>
        <DockPanel x:Name="RampRow" Grid.Row="5" Grid.Column="1" Margin="8,0,0,0">
            <TextBlock x:Name="RampLabel" Text="0.15 /block" Width="110" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Slider x:Name="RampSlider" Minimum="0.05" Maximum="1.0" Value="0.15" TickFrequency="0.05" IsMoveToPointEnabled="True" IsSnapToTickEnabled="True" TickPlacement="BottomRight" ValueChanged="RampSlider_ValueChanged"/>
        </DockPanel>

        <Label x:Name="EchoDelayLabelLeft" Grid.Row="6" Grid.Column="0" Content="Delay:" VerticalAlignment="Center"/>
        <DockPanel x:Name="EchoDelayRow" Grid.Row="6" Grid.Column="1" Margin="8,0,0,0">
            <TextBlock x:Name="EchoDelayLabel" Text="+0 ms" Width="110" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Slider x:Name="EchoDelaySlider" Minimum="0" Maximum="1000" Value="0" TickFrequency="100" IsMoveToPointEnabled="True" IsSnapToTickEnabled="True" TickPlacement="BottomRight" ValueChanged="EchoDelaySlider_ValueChanged"/>
        </DockPanel>

        <Label x:Name="EchoVolumeLabelLeft" Grid.Row="7" Grid.Column="0" Content="Volume:" VerticalAlignment="Center"/>
        <DockPanel x:Name="EchoVolumeRow" Grid.Row="7" Grid.Column="1" Margin="8,0,0,0">
            <TextBlock x:Name="EchoVolumeLabel" Text="+0.0" Width="110" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="8,0,0,0"/>
            <Slider x:Name="EchoVolumeSlider" Minimum="0" Maximum="1" Value="0" SmallChange="0.05" LargeChange="0.1" TickFrequency="0.05" IsMoveToPointEnabled="True" IsSnapToTickEnabled="True" TickPlacement="BottomRight" ValueChanged="EchoVolumeSlider_ValueChanged"/>
        </DockPanel>

        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="8,16,0,0">
            <Button x:Name="StartButton" Content="Start" Width="80" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="Stop" Width="80" Margin="8,0,0,0" Click="StopButton_Click" IsEnabled="False"/>
        </StackPanel>

        <TextBlock Grid.Row="10" Grid.ColumnSpan="2" x:Name="StatusLabel" Text="Status: idle" Margin="0,16,0,0" FontStyle="Italic"/>
    </Grid>
</Window>
