{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git branch)",
      "Bash(git remote:*)",
      "Bash(git remote)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(git tag:*)",
      "Bash(git tag)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)",
      "Bash(git reflog:*)",
      "Bash(git reflog)",
      "Bash(git shortlog:*)",
      "Bash(git cat-file:*)",
      "Bash(git grep:*)",
      "Bash(git fetch:*)",
      "Bash(git fetch)"
