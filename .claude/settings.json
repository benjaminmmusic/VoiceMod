      "Bash(git restore --:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(git reflog delete:*)",
      "Bash(git update-ref -d:*)",
      "Bash(git gc:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)"
    ]
  }
}
